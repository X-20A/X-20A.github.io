{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"strict": true,
		"jsx": "preserve",
		"importHelpers": true,
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"noEmit": true,
		"isolatedModules": true,
		"strictFunctionTypes": true,
		"strictNullChecks": true,
		"lib": [
			"esnext",
			"dom",
			"dom.iterable"
		]
	},
	"include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts"]
}
