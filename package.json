{
  "name": "compass_sim",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test:watch": "vitest watch --include=tests/watch/*.test.ts",
    "rand-test": "vitest --run -t 'rand-test'",
    "route-test": "vitest --run -t 'route-test'",
    "data-test": "vitest --run -t 'data-test'",
    "speed-test": "vitest --run -t 'speed-test'",
    "quest-test": "vitest --run -t 'quest-test'",
    "bonus-test": "vitest --run -t 'bonus-test'",
    "tests": "vitest run",
    "tsc": "vue-tsc --noEmit",
    "dep": "depcheck",
    "lint": "biome lint",
    "format": "biome format",
    "download-banner": "bun run scripts/downloadBanner.ts",
    "gen-type": "bun run scripts/generateUnion.ts && bun run scripts/generateBaseShipNameUnion.ts"
  },
  "dependencies": {
    "@biomejs/biome": "^1.9.4",
    "baseline-browser-mapping": "^2.10.43",
    "big.js": "^6.2.2",
    "caniuse-lite": "^1.0.30001806",
    "gkcoi": "^1.7.0",
    "lz-string": "^1.5.0",
    "pinia": "^3.0.4",
    "rollup-plugin-visualizer": "^5.14.0",
    "terser": "^5.49.0",
    "valibot": "^1.4.2",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-vue-devtools": "^7.7.10",
    "vue": "^3.5.40"
  },
  "devDependencies": {
    "@types/big.js": "^6.2.2",
    "@types/node": "^22.20.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/ui": "^3.2.7",
    "jsdom": "^26.1.0",
    "typescript": "^6.0.0",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-svg-icons": "^2.0.1",
    "vitest": "^3.2.7",
    "vue-tsc": "^2.2.12"
  }
}
